// Taylor expansion of exp(B)
#let texp(B) = {
  let (R,C,f) = (vec-0(1),B,1)
  for i in range(20) {
    R = add(R,muls(C,1/f))
    C = gp(C,B)
    f = f * (i+2)
  }
  R
}

// Inverse of a multivector 
#let inv(x) = {
  let xc = conj(x)
  let xn = neg34(gp(x,xc))
  let iv = gp(xc,xn)
  let xi = gp(x,iv) // should be a scalar
  muls(iv,1/scalar(xi)) // normalize it
}

