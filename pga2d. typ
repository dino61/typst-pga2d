#let inv(x) = {
  let iv = gp( gp(conj(x),hat(x)), rev(x))
  let xi = gp(x,iv) // should be a scalar
  return muls(iv, 1/scalar(xi)) // normalize it
}

// run tests
#let logerr(name,val,exp, tol: 1e-15) = {
  let sum = 0; let n = exp.len()
  for (a,b) in val.zip(exp) {
    sum += (a - b)*(a - b)
  }
  if sum > tol*n [
    Test: '#name' error: #sum \
    `  val:`#val\
    `  exp:`#exp\
  ] else []
}

